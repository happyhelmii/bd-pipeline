  document.getElementById('modal-root').innerHTML=`
  <div class="ov" onclick="ovClick(event)">
    <div class="modal">
      <div class="mhd"><span style="font-size:30px">🪿</span><h3>${S.editId?'Edit Meeting':'Add New Meeting'}</h3></div>
      <div class="fg">
        <div class="fld"><div class="flb">🏢 Company</div><input class="fi" type="text" value="${esc(f.company)}" oninput="sf('company',this.value)" placeholder="e.g. Krafton"></div>
        <div class="fld"><div class="flb">📱 App</div><input class="fi" type="text" value="${esc(f.app)}" oninput="sf('app',this.value)" placeholder="e.g. PUBG Mobile"></div>
        <div class="fld"><div class="flb">📅 Date</div><input class="fi" type="date" value="${f.date}" oninput="sf('date',this.value)"></div>
        <div class="fld"><div class="flb">🪿 BDR</div><input class="fi" type="text" value="${esc(f.bdr)}" oninput="sf('bdr',this.value)" placeholder="e.g. Hye Yeon"></div>
        <div class="fld f2"><div class="flb">💼 Seller</div><input class="fi" type="text" value="${esc(f.seller)}" oninput="sf('seller',this.value)" placeholder="e.g. Sean"></div>
        <div class="fld"><div class="flb">📥 Downloads</div><div class="nw"><input class="fi" type="number" value="${f.dl}" oninput="sf('dl',this.value)" placeholder="2000000">${f.dl?`<span class="nfmt">${fmtNum(f.dl)}</span>`:''}</div></div>
        <div class="fld"><div class="flb">👥 DAU</div><div class="nw"><input class="fi" type="number" value="${f.dau}" oninput="sf('dau',this.value)" placeholder="50000">${f.dau?`<span class="nfmt">${fmtNum(f.dau)}</span>`:''}</div></div>
        <div class="fld f2"><div class="flb">🔗 MMP</div>
          <div class="ms">
            <div class="mr"><input type="checkbox" id="mc" ${f.mmp?'checked':''} onchange="sf('mmp',this.checked)"><label for="mc">Using MMP</label></div>
            ${f.mmp?`<div class="mo">${MMP_LIST.map(m=>`<button class="mopt${f.mmpTool===m?' sl':''}" onclick="sMMP('${m}')">${m}</button>`).join('')}</div>${f.mmpTool==='Other'?`<input class="fi" style="margin-top:7px" type="text" value="${esc(f.mmpOther)}" oninput="sf('mmpOther',this.value)" placeholder="Specify MMP...">`:''}`:''}
          </div>
        </div>
        <div class="fld f2"><div class="flb">🤖 Android Store Link</div><input class="fi" type="url" value="${esc(f.androidUrl)}" oninput="sf('androidUrl',this.value)" placeholder="https://play.google.com/store/apps/..."></div>
        <div class="fld f2"><div class="flb">🍎 iOS App Store Link</div><input class="fi" type="url" value="${esc(f.iosUrl)}" oninput="sf('iosUrl',this.value)" placeholder="https://apps.apple.com/..."></div>
        <div class="fld f2"><div class="flb">☁️ Salesforce Link</div><input class="fi" type="url" value="${esc(f.sfLink)}" oninput="sf('sfLink',this.value)" placeholder="https://appier.lightning.force.com/..."></div>
        <div class="fld f2"><div class="flb">🥚 FSQL Status</div>
          <div class="fsql-opts">
            <button class="fsql-opt ${f.fsqlStatus==='fsql'?'sel-fsql':''}" onclick="sf('fsqlStatus','fsql')">🥚 FSQL</button>
            <button class="fsql-opt ${f.fsqlStatus==='yet'?'sel-yet':''}" onclick="sf('fsqlStatus','yet')">⏳ Yet-FSQL</button>
            <button class="fsql-opt ${f.fsqlStatus==='nfsql'?'sel-nfsql':''}" onclick="sf('fsqlStatus','nfsql')">🪹 Non-FSQL</button>
          </div>
          ${sp?`<div class="fp ${auto==='fsql'?'yes':'no'}">${auto==='fsql'?'🥚 Auto-detected: FSQL!':'🪹 Auto-detected: Not yet qualified'}</div>`:''}
        </div>
        <div class="fld f2"><div class="flb">✅ Qualifications</div>
          <div class="qr">
            <div class="qc ${f.paCheck?'on':''}" onclick="tQ('paCheck')">
              <input type="checkbox" ${f.paCheck?'checked':''} onchange="sf('paCheck',this.checked)" onclick="event.stopPropagation()">
              <label>🎯 PA Check</label>
            </div>
          </div>
        </div>
        <div class="fld f2"><div class="flb">💬 Notes</div><textarea class="fi" oninput="sf('note',this.value)" placeholder="Briefly summarize...">${esc(f.note)}</textarea></div>
      </div>
      <div class="ma">
        <button class="mc" onclick="closeM()">Cancel</button>
        <button class="msv" id="save-btn" onclick="saveCard()">🥚 Save Meeting</button>
      </div>
    </div>
  </div>`;
}

function renderToast(){
  document.getElementById('toast-root').innerHTML=S.showMgr
    ?`<div class="mgr-toast"><div class="mgr-bubble">${S.mgrMsg}</div><img class="mgr-photo" src="${MGR_IMG}" alt="Manager"></div>`
    :'';
}

function renderOnboard(){
  if(S.bdrName){document.getElementById('header-root').querySelector && renderHeader();return;}
  document.getElementById('header-root').innerHTML=`
  <div class="obw"><div class="obb">
    <div class="ob-scene"><span class="ob-g">🪿</span><div class="ob-eggs">${['🥚','🥚','🥚'].map((e,i)=>`<span class="ob-e" style="animation-delay:${.3+i*.12}s">${e}</span>`).join('')}</div></div>
    <div class="obt">K-Golden Goose</div>
    <div class="obs">Appier BDR Weekly Review ✨<br>같이 황금알 낳으러 가요!</div>
    <input class="obi" id="obn" type="text" placeholder="Your name (e.g. Hye Yeon)"/>
    <button class="obbt" onclick="setBDR()">🥚 알 낳으러 Go!</button>
  </div></div>`;
}

function render(){
  if(!S.bdrName){renderOnboard();return;}
  renderHeader();
  renderMain();
  renderModal();
  renderToast();
}

// Only re-render modal (no scroll jump for number input)
function renderModalOnly(){
  renderModal();
}

function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

function renderCal(){
  const{calY:y,calM:m}=S;
  const mm={};S.cards.forEach(c=>{if(c.date){if(!mm[c.date])mm[c.date]=[];mm[c.date].push(c);}});
  const t=new Date(),fd=new Date(y,m,1).getDay(),dim=new Date(y,m+1,0).getDate();
  let h=`<div class="sc"><div class="ch"><button class="cb" onclick="calP()">‹</button><span class="ct">${MONTHS[m]} ${y}</span><button class="cb" onclick="calN()">›</button></div>
<div class="cg">${DOWS.map(d=>`<div class="cdow">${d}</div>`).join('')}`;
  for(let i=0;i<fd;i++)h+=`<div class="cd fd"></div>`;
  for(let d=1;d<=dim;d++){
    const ds=`${y}-${String(m+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
    const iT=t.getFullYear()===y&&t.getMonth()===m&&t.getDate()===d;
    const hM=mm[ds];
    h+=`<div class="cd${iT?' td':''}${hM?' hm':''}" ${hM?`onclick="sCard('${ds}')" title="${hM.map(c=>c.company).join(', ')}"`:''}>
      ${d}${hM?'<span class="cdot"></span>':''}
    </div>`;
  }
  h+=`</div>`;
  const tmc=S.cards.filter(c=>{if(!c.date)return false;const[cy,cm2]=c.date.split('-');return+cy===y&&+cm2-1===m;});
  if(tmc.length){h+=`<div class="cml"><div class="cmlt">This Month</div>`;tmc.forEach(c=>{const dc=c.fsqlStatus==='fsql'?'#C98E00':c.fsqlStatus==='yet'?'#E07000':'#C03030';h+=`<div class="cmi" onclick="sCard('${c.date}')"><span class="cdt" style="background:${dc}"></span>${c.company} · ${c.date.slice(5)}</div>`;});h+=`</div>`;}
  return h+'</div>';
}
function renderWF(weeks){
  let h=`<div class="sc"><div class="wft">📅 Filter by Week</div><div class="wfl">`;
  h+=`<div class="wfi ${!S.fw?'on':''}" onclick="setW(null)">All Time <span class="wfc">${S.cards.length}</span></div>`;
  weeks.forEach(w=>{const cnt=S.cards.filter(c=>getWeekOf(c.date)===w).length;h+=`<div class="wfi ${S.fw===w?'on':''}" onclick="setW('${w}')">${weekLabel(w)} <span class="wfc">${cnt}</span></div>`;});
  return h+'</div></div>';
}

function cardH(c){
  const isF=c.fsqlStatus==='fsql',isY=c.fsqlStatus==='yet';
  const dlOk=+c.dl>=DL_TH,dauOk=+c.dau>=DAU_TH;
  const mmpD=c.mmp?(c.mmpTool==='Other'?c.mmpOther||'Other':c.mmpTool||'Yes'):'No';
  const bc=isF?'b-fsql':isY?'b-yet':'b-nfsql';
  const bt=isF?'🥚 FSQL':isY?'⏳ Yet-FSQL':'🪹 Non-FSQL';
  const cc=isF?'c-fsql':isY?'c-yet':'c-nfsql';
  return`<div class="card ${cc}" id="card-${c.id}">
<div class="cr1"><div><div class="cn">${esc(c.company)}</div>${c.app&&c.app!==c.company?`<div class="ca">${esc(c.app)}</div>`:''}</div>
<div class="cbs"><span class="bg ${bc}">${bt}</span>${c.paCheck?`<span class="bg b-pa">🎯 PA</span>`:''}</div></div>
<div class="cmt"><span class="mp">📅 ${c.date}</span><span class="mp">🪿 ${esc(c.bdr)}</span>${c.seller?`<span class="mp">💼 ${esc(c.seller)}</span>`:''}</div>
<div class="cda">
  <div class="db"><div class="dl">Downloads</div><div class="dv ${dlOk?'ok':'no'}">${fmtNum(c.dl)}</div></div>
  <div class="db"><div class="dl">DAU</div><div class="dv ${dauOk?'ok':'no'}">${fmtNum(c.dau)}</div></div>
  <div class="db"><div class="dl">MMP</div><div class="dv ${c.mmp?'gd2':'no'}">${esc(mmpD)}</div></div>
  <div class="db"><div class="dl">Status</div><div class="dv ${isF?'ok':isY?'':'no'}" style="${isY?'color:var(--or)':''}">${isF?'✓ FSQL':isY?'⏳ Yet':'✗ No'}</div></div>
</div>
${(c.androidUrl||c.iosUrl||c.sfLink)?`<div class="cls">
  ${c.androidUrl?`<a href="${esc(c.androidUrl)}" target="_blank" class="al la">🤖 Android</a>`:''}
  ${c.iosUrl?`<a href="${esc(c.iosUrl)}" target="_blank" class="al li">🍎 iOS</a>`:''}
  ${c.sfLink?`<a href="${esc(c.sfLink)}" target="_blank" class="al lsf">☁️ SF</a>`:''}
</div>`:''}
${c.note?`<hr class="cdiv"><div class="cnote">💬 ${esc(c.note)}</div>`:''}
${c.leaderComment?`<div class="ldb"><span class="ldi">⭐</span><div><div class="ldl">Sales Leader</div><div class="ldt">${esc(c.leaderComment)}</div></div></div>`:''}
<div class="cact">
  <button class="csm" onclick="openEdit(${c.id})">✏️ Edit</button>
  <button class="csm" onclick="togLdr(${c.id})">${c.leaderComment?'⭐ Edit':'⭐ Leader'}</button>
  <button class="csm del" onclick="delCard(${c.id})" style="margin-left:auto">🗑</button>
</div>
${S.ldrId===c.id?`<div class="lir"><input id="lc-${c.id}" type="text" placeholder="Leader comment..." value="${esc(c.leaderComment||'')}"><button class="lsb" onclick="saveLdr(${c.id})">💾 Save</button></div>`:''}
</div>`;
}

// ── Actions ──────────────────────────────────────────────────────────────
function setBDR(){const v=document.getElementById('obn')?.value?.trim();if(!v)return;S.bdrName=v;localStorage.setItem('kgg_bdr',v);render();}
function resetBDR(){if(confirm('Change your name?')){S.bdrName='';localStorage.removeItem('kgg_bdr');render();}}
function calP(){S.calM--;if(S.calM<0){S.calM=11;S.calY--;}renderMain();}
function calN(){S.calM++;if(S.calM>11){S.calM=0;S.calY++;}renderMain();}
function setW(w){S.fw=w;renderMain();}
function sCard(date){const c=S.cards.find(x=>x.date===date);if(c){const el=document.getElementById('card-'+c.id);if(el)el.scrollIntoView({behavior:'smooth',block:'center'});}}
function openAdd(){S.modal=true;S.editId=null;S.form=emptyForm();S.form.bdr=S.bdrName;renderModal();}
function openEdit(id){const c=S.cards.find(x=>x.id===id);S.modal=true;S.editId=id;S.form={...c};renderModal();}
function closeM(){S.modal=false;renderModal();}
function ovClick(e){if(e.target.classList.contains('ov'))closeM();}

// sf() only re-renders modal to avoid scroll jump
function sf(k,v){
  S.form[k]=v;
  // For checkboxes and FSQL status buttons, re-render modal only
  renderModalOnly();
}
function tQ(k){S.form[k]=!S.form[k];renderModalOnly();}
function sMMP(t){S.form.mmpTool=t;S.form.mmpOther='';renderModalOnly();}

async function saveCard(){
  const f=S.form;
  if(!f.company.trim())return;
  const btn=document.getElementById('save-btn');
  if(btn){btn.disabled=true;btn.textContent='💾 Saving...';}
  const isNew=!S.editId;
  const card={...f,id:S.editId||Date.now()};
  if(S.editId){
    const i=S.cards.findIndex(x=>x.id===S.editId);
    S.cards[i]=card;
  }else{
    S.cards.push(card);
  }
  saveLocal(S.cards);
  // Sync to Notion
  await syncToNotion(card);
  S.modal=false;
  render();
  if(isNew)showMgr();
}

function delCard(id){
  if(!confirm('Delete this meeting?'))return;
  S.cards=S.cards.filter(x=>x.id!==id);
  saveLocal(S.cards);
  renderMain();
}
function togLdr(id){S.ldrId=S.ldrId===id?null:id;renderMain();}
function saveLdr(id){
  const v=document.getElementById('lc-'+id)?.value||'';
  const i=S.cards.findIndex(x=>x.id===id);
  S.cards[i].leaderComment=v;
  saveLocal(S.cards);
  S.ldrId=null;
  renderMain();
}
function showMgr(){
  S.mgrMsg=MGR_MSGS[Math.floor(Math.random()*MGR_MSGS.length)];
  S.showMgr=true;renderToast();
  clearTimeout(S.mgrTimer);
  S.mgrTimer=setTimeout(()=>{
    const el=document.querySelector('.mgr-toast');
    if(el){el.classList.add('out');setTimeout(()=>{S.showMgr=false;renderToast();},380);}
  },3000);
}

render();
</script>
</body>
