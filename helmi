  const eggs=fy>0?Array.from({length:Math.min(fy,12)},(_,i)=>`<span class="egg-i" style="animation-delay:${i*.06}s">🥚</span>`).join(''):`<span class="egg-empty">No eggs yet… 🪹</span>`;

  document.getElementById('main-root').innerHTML=`
  <div class="wrap">
    <div class="sidebar">
      <div class="sc">
        <div class="egg-title">🥚 Golden Eggs (FSQL)</div>
        <div class="egg-row">${eggs}</div>
      </div>
      ${renderCal()}
      ${weeks.length?renderWF(weeks):''}
    </div>
    <div class="main">
      <div class="summary">
        <div class="stat"><span class="si">📋</span><div class="sl">Meetings</div><div class="sv">${tot}</div></div>
        <div class="stat sgd"><span class="si">🥚</span><div class="sl">FSQL</div><div class="sv gd">${fy}</div></div>
        <div class="stat"><span class="si">⏳</span><div class="sl">Yet-FSQL</div><div class="sv or">${yet}</div></div>
        <div class="stat sbl"><span class="si">🎯</span><div class="sl">PA</div><div class="sv bl">${pa}</div></div>
      </div>
      <div class="stop">
        <div class="stitle">🪺 ${S.fw?`Week of ${weekLabel(S.fw)}`:'All Meetings'}</div>
        <button class="badd" onclick="openAdd()">🪿 Add Meeting</button>
      </div>
      <div class="cards">${tot===0?`<div class="empty">🪿<br>No golden eggs yet!<br>Add your first meeting! 🥚</div>`:fc.map(cardH).join('')}</div>
    </div>
  </div>`;
}

