<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>🪿 K-Golden Goose</title>
<link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#FFFDF0;--sf:#FFF;--sf2:#FFFBEE;--bd:#EEE4A8;
  --tx:#2A2610;--tx2:#78704A;--tx3:#B8AC78;
  --gd:#F0B800;--gdbg:#FFF8CC;--gdk:#8A6000;--gdm:#D4960A;
  --gr:#18784A;--grbg:#E6F8EE;--grb:#9ADCBA;
  --rd:#C03030;--rdbg:#FCEAEA;--rdb:#F0BABA;
  --or:#E07000;--orbg:#FFF0DC;--orb:#F8C880;
  --bl:#2563EB;--blbg:#EFF6FF;--blb:#BFDBFE;
  --pu:#7C3AED;--pubg:#F5F3FF;--pub:#C4B5FD;
  --r:14px;--rlg:22px;--rxl:28px;
}
*{box-sizing:border-box;margin:0;padding:0;}
body{font-family:'Nunito',sans-serif;background:var(--bg);color:var(--tx);min-height:100vh;}
body::before{content:'';position:fixed;inset:0;z-index:-1;background-image:radial-gradient(#EEE0A0 1.5px,transparent 1.5px);background-size:30px 30px;opacity:.4;}
.app{display:flex;flex-direction:column;min-height:100vh;}
header{background:rgba(255,255,255,.94);backdrop-filter:blur(12px);border-bottom:3px solid var(--bd);padding:0 24px;height:68px;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:200;}
.logo{display:flex;align-items:center;gap:12px;}
.logo-goose{font-size:36px;animation:waddle 2s ease-in-out infinite;}
@keyframes waddle{0%,100%{transform:rotate(0)}25%{transform:rotate(-9deg) translateY(-2px)}75%{transform:rotate(7deg) translateY(-2px)}}
.logo-txt .t{font-size:17px;font-weight:900;color:var(--gdk);}
.logo-txt .s{font-size:11px;color:var(--tx3);font-weight:600;}
.hdr-r{display:flex;align-items:center;gap:10px;}
.wchip{font-size:11px;font-family:'DM Mono',monospace;background:var(--gdbg);border:2px solid var(--bd);padding:5px 13px;border-radius:100px;color:var(--gdk);font-weight:700;}
.bpill{font-size:12px;font-weight:900;background:linear-gradient(135deg,var(--gdm),var(--gdk));color:#FFF7CC;padding:7px 16px;border-radius:100px;cursor:pointer;box-shadow:0 3px 10px rgba(180,130,0,.3);}
.notion-status{font-size:11px;font-weight:700;padding:4px 11px;border-radius:100px;border:2px solid;cursor:default;}
.notion-status.syncing{color:var(--gdk);background:var(--gdbg);border-color:var(--bd);animation:pulse .8s ease-in-out infinite;}
.notion-status.synced{color:var(--gr);background:var(--grbg);border-color:var(--grb);}
.notion-status.failed{color:var(--rd);background:var(--rdbg);border-color:var(--rdb);}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.obw{position:fixed;inset:0;background:rgba(40,35,10,.6);backdrop-filter:blur(8px);display:flex;align-items:center;justify-content:center;z-index:400;padding:16px;}
.obb{background:var(--sf);border-radius:var(--rxl);padding:44px 36px 36px;max-width:380px;width:100%;text-align:center;border:3px solid var(--bd);box-shadow:0 24px 60px rgba(180,130,0,.2);}
.ob-scene{height:80px;display:flex;align-items:flex-end;justify-content:center;gap:6px;margin-bottom:16px;}
.ob-g{font-size:60px;animation:waddle 1.4s ease-in-out infinite;}
.ob-eggs{display:flex;gap:4px;align-items:flex-end;}
.ob-e{font-size:22px;animation:epop .4s cubic-bezier(.34,1.56,.64,1) backwards;}
@keyframes epop{0%{transform:scale(0) rotate(-20deg);opacity:0}100%{transform:scale(1) rotate(0);opacity:1}}
.obt{font-size:26px;font-weight:900;color:var(--gdk);margin-bottom:6px;}
.obs{font-size:13px;color:var(--tx2);line-height:1.7;margin-bottom:24px;}
.obi{width:100%;font-family:inherit;font-size:15px;font-weight:800;padding:13px 16px;border:2.5px solid var(--bd);border-radius:var(--r);background:var(--bg);color:var(--tx);outline:none;text-align:center;margin-bottom:12px;}
.obi:focus{border-color:var(--gd);}
.obbt{width:100%;padding:13px;border:none;border-radius:var(--r);background:linear-gradient(135deg,var(--gd),var(--gdk));color:#FFF7CC;font-family:inherit;font-size:15px;font-weight:900;cursor:pointer;box-shadow:0 5px 16px rgba(180,130,0,.35);}
.wrap{display:flex;gap:20px;flex:1;padding:24px;max-width:1120px;margin:0 auto;width:100%;}
.sidebar{width:240px;flex-shrink:0;display:flex;flex-direction:column;gap:14px;}
.sc{background:var(--sf);border:2.5px solid var(--bd);border-radius:var(--rlg);padding:16px;position:sticky;top:82px;}
.egg-title{font-size:10px;font-weight:900;color:var(--tx3);text-transform:uppercase;letter-spacing:.7px;margin-bottom:10px;text-align:center;}
.egg-row{display:flex;flex-wrap:wrap;gap:4px;justify-content:center;min-height:32px;align-items:center;}
.egg-i{font-size:22px;animation:epop .3s cubic-bezier(.34,1.56,.64,1) backwards;}
.egg-empty{font-size:12px;color:var(--tx3);font-weight:600;text-align:center;}
.ch{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px;}
.ct{font-size:13px;font-weight:900;color:var(--gdk);}
.cb{background:none;border:2px solid var(--bd);border-radius:8px;padding:3px 9px;font-size:14px;cursor:pointer;color:var(--tx2);font-family:inherit;font-weight:800;}
.cb:hover{background:var(--gdbg);}
.cg{display:grid;grid-template-columns:repeat(7,1fr);gap:2px;}
.cdow{font-size:8px;font-weight:900;color:var(--tx3);text-align:center;padding:3px 0;text-transform:uppercase;}
.cd{aspect-ratio:1;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;border-radius:7px;color:var(--tx2);position:relative;cursor:default;}
.cd.fd{color:var(--tx3);}
.cd.td{background:var(--gdbg);color:var(--gdk);border:2px solid var(--gd);font-weight:900;}
.cd.hm{background:var(--grbg);color:var(--gr);border:2px solid var(--grb);cursor:pointer;font-weight:900;}
.cd.hm:hover{background:#BAECD4;}
.cdot{width:4px;height:4px;background:var(--gdm);border-radius:50%;position:absolute;bottom:1px;left:50%;transform:translateX(-50%);}
.cml{margin-top:12px;padding-top:10px;border-top:2px dashed var(--bd);}
.cmlt{font-size:9px;font-weight:900;color:var(--tx3);text-transform:uppercase;letter-spacing:.6px;margin-bottom:8px;}
.cmi{display:flex;align-items:center;gap:7px;font-size:11px;font-weight:700;color:var(--tx2);margin-bottom:5px;cursor:pointer;padding:4px 6px;border-radius:7px;}
.cmi:hover{background:var(--sf2);}
.cdt{width:7px;height:7px;border-radius:50%;flex-shrink:0;}
.wft{font-size:10px;font-weight:900;color:var(--tx3);text-transform:uppercase;letter-spacing:.6px;margin-bottom:8px;}
.wfl{display:flex;flex-direction:column;gap:5px;}
.wfi{font-size:11px;font-weight:700;color:var(--tx2);padding:7px 10px;border-radius:9px;cursor:pointer;border:2px solid transparent;display:flex;align-items:center;justify-content:space-between;}
.wfi:hover{background:var(--gdbg);color:var(--gdk);}
.wfi.on{background:var(--gdbg);color:var(--gdk);border-color:var(--gd);}
.wfc{font-size:10px;background:var(--bd);color:var(--tx2);padding:1px 7px;border-radius:100px;font-weight:800;}
.wfi.on .wfc{background:var(--gd);color:#fff;}
.main{flex:1;min-width:0;}
.summary{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:24px;}
.stat{background:var(--sf);border:2.5px solid var(--bd);border-radius:var(--rlg);padding:16px 12px;text-align:center;transition:.15s;}
.stat:hover{transform:translateY(-2px);box-shadow:0 6px 18px rgba(0,0,0,.07);}
.sgd{background:var(--gdbg);border-color:#EED060;}
.sbl{background:var(--blbg);border-color:var(--blb);}
.si{font-size:24px;display:block;margin-bottom:6px;}
.sl{font-size:9px;color:var(--tx3);text-transform:uppercase;letter-spacing:.7px;margin-bottom:5px;font-weight:800;}
.sv{font-size:30px;font-weight:900;letter-spacing:-1px;}
.sv.gd{color:var(--gdk);}
.sv.or{color:var(--or);}
.sv.bl{color:var(--bl);}
.stop{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;}
.stitle{font-size:11px;font-weight:900;color:var(--tx3);text-transform:uppercase;letter-spacing:.8px;}
.badd{display:flex;align-items:center;gap:7px;background:linear-gradient(135deg,var(--gd),var(--gdk));color:#FFF7CC;border:none;padding:10px 20px;border-radius:var(--r);font-size:13px;font-weight:900;cursor:pointer;font-family:inherit;box-shadow:0 4px 12px rgba(180,130,0,.3);}
.badd:hover{opacity:.9;transform:translateY(-1px);}
.cards{display:flex;flex-direction:column;gap:14px;}
.card{background:var(--sf);border:2.5px solid var(--bd);border-radius:var(--rlg);padding:20px 22px;transition:border-color .2s,box-shadow .2s,transform .2s;position:relative;overflow:hidden;}
.card::after{content:'';position:absolute;top:0;left:0;right:0;height:5px;}
.card.c-fsql::after{background:linear-gradient(90deg,#FFD700,var(--gdm),#FFD700);}
.card.c-yet::after{background:linear-gradient(90deg,var(--or),#FFB030);}
.card.c-nfsql::after{background:linear-gradient(90deg,var(--rd),#E06060);}
.card:hover{border-color:#DDD060;box-shadow:0 10px 28px rgba(180,130,0,.12);}
.cr1{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:8px;}
.cn{font-size:16px;font-weight:900;letter-spacing:-.3px;}
.ca{font-size:12px;color:var(--tx2);font-weight:600;margin-top:2px;}
.cbs{display:flex;gap:6px;flex-wrap:wrap;flex-shrink:0;}
.bg{font-size:11px;font-weight:800;padding:5px 13px;border-radius:100px;border:2px solid;white-space:nowrap;}
.b-fsql{background:var(--gdbg);color:var(--gdk);border-color:#EED060;}
.b-yet{background:var(--orbg);color:var(--or);border-color:var(--orb);}
.b-nfsql{background:var(--rdbg);color:var(--rd);border-color:var(--rdb);}
.b-pa{background:var(--blbg);color:var(--bl);border-color:var(--blb);}
.cmt{display:flex;gap:7px;flex-wrap:wrap;margin-bottom:12px;}
.mp{font-size:11px;font-weight:700;color:var(--tx2);background:var(--sf2);border:1.5px solid var(--bd);padding:3px 10px;border-radius:100px;}
.cda{display:grid;grid-template-columns:repeat(4,1fr);gap:7px;margin-bottom:12px;}
.db{background:var(--sf2);border-radius:10px;padding:9px 8px;border:2px solid var(--bd);text-align:center;}
.dl{font-size:8px;color:var(--tx3);text-transform:uppercase;letter-spacing:.4px;margin-bottom:3px;font-weight:900;}
.dv{font-size:13px;font-weight:800;font-family:'DM Mono',monospace;}
.dv.ok{color:var(--gr);}
.dv.no{color:var(--rd);}
.dv.gd2{color:var(--gdk);}
.cls{display:flex;gap:8px;margin-bottom:10px;flex-wrap:wrap;}
.al{display:inline-flex;align-items:center;gap:5px;font-size:11px;font-weight:800;padding:5px 13px;border-radius:100px;border:2px solid;text-decoration:none;}
.la{color:#2E7D32;background:#F1F8E9;border-color:#A5D6A7;}
.la:hover{background:#DCEDC8;}
.li{color:#1565C0;background:#E3F2FD;border-color:#90CAF9;}
.li:hover{background:#BBDEFB;}
.lsf{color:var(--pu);background:var(--pubg);border-color:var(--pub);}
.lsf:hover{background:#EDE9FE;}
.cdiv{border:none;border-top:2px dashed var(--bd);margin:10px 0;}
.cnote{font-size:13px;color:var(--tx2);line-height:1.7;font-weight:600;margin-bottom:8px;}
.ldb{background:#FFFBEA;border:2px solid #EDE4C0;border-radius:12px;padding:10px 14px;margin-bottom:8px;display:flex;gap:8px;}
.ldi{font-size:16px;flex-shrink:0;margin-top:1px;}
.ldl{font-size:9px;text-transform:uppercase;letter-spacing:.5px;color:#9A8840;margin-bottom:2px;font-weight:900;}
.ldt{font-size:13px;color:#5A4A18;font-weight:600;}
.cact{display:flex;gap:7px;flex-wrap:wrap;}
.csm{font-size:11px;font-family:inherit;font-weight:800;padding:5px 13px;border:2px solid var(--bd);border-radius:100px;background:var(--sf2);color:var(--tx2);cursor:pointer;}
.csm:hover{background:var(--gdbg);color:var(--gdk);}
.csm.del{color:var(--rd);background:var(--rdbg);border-color:var(--rdb);}
.lir{display:flex;gap:8px;margin-top:10px;}
.lir input{flex:1;font-family:inherit;font-size:13px;font-weight:600;padding:8px 11px;border:2px solid var(--bd);border-radius:10px;background:var(--sf);color:var(--tx);outline:none;}
.lir input:focus{border-color:var(--gd);}
.lsb{font-size:12px;font-family:inherit;padding:8px 14px;border:2px solid var(--bd);border-radius:10px;background:var(--gdbg);color:var(--gdk);cursor:pointer;font-weight:900;white-space:nowrap;}
.empty{text-align:center;padding:60px 20px;color:var(--tx3);font-size:14px;line-height:2.5;font-weight:700;}
/* Manager toast */
.mgr-toast{position:fixed;bottom:28px;right:28px;z-index:500;display:flex;align-items:flex-end;gap:10px;animation:toast-in .5s cubic-bezier(.34,1.56,.64,1);}
@keyframes toast-in{0%{transform:translateY(80px) scale(.7);opacity:0}100%{transform:translateY(0) scale(1);opacity:1}}
.mgr-toast.out{animation:toast-out .35s ease-in forwards;}
@keyframes toast-out{100%{transform:translateY(80px) scale(.7);opacity:0}}
.mgr-bubble{background:var(--sf);border:3px solid var(--bd);border-radius:20px 20px 4px 20px;padding:12px 16px;font-size:14px;font-weight:900;color:var(--gdk);box-shadow:0 8px 28px rgba(180,130,0,.22);position:relative;max-width:170px;text-align:center;line-height:1.5;}
.mgr-bubble::after{content:'';position:absolute;bottom:-16px;right:16px;border:8px solid transparent;border-top-color:var(--bd);}
.mgr-bubble::before{content:'';position:absolute;bottom:-11px;right:17px;border:7px solid transparent;border-top-color:var(--sf);z-index:1;}
.mgr-photo{width:68px;height:68px;border-radius:50%;object-fit:cover;border:3px solid var(--bd);box-shadow:0 4px 14px rgba(0,0,0,.2);animation:mgr-bob .7s ease-in-out infinite alternate;}
@keyframes mgr-bob{0%{transform:translateY(0) rotate(-3deg)}100%{transform:translateY(-8px) rotate(3deg)}}
/* Modal - fixed overlay, no scroll jump */
.ov{position:fixed;inset:0;background:rgba(40,35,10,.52);backdrop-filter:blur(6px);display:flex;align-items:center;justify-content:center;z-index:300;overflow-y:auto;padding:20px;}
.modal{background:var(--sf);border-radius:var(--rxl);border:3px solid var(--bd);padding:28px;width:100%;max-width:540px;box-shadow:0 24px 60px rgba(180,130,0,.16);max-height:90vh;overflow-y:auto;}
.mhd{display:flex;align-items:center;gap:10px;margin-bottom:22px;}
.mhd h3{font-size:20px;font-weight:900;color:var(--gdk);}
.fg{display:grid;grid-template-columns:1fr 1fr;gap:12px;}
.f2{grid-column:1/-1;}
.fld{display:flex;flex-direction:column;gap:5px;margin-bottom:10px;}
.flb{font-size:9px;color:var(--tx3);text-transform:uppercase;letter-spacing:.7px;font-weight:900;}
.fi{font-family:inherit;font-size:13px;font-weight:700;padding:10px 12px;border:2.5px solid var(--bd);border-radius:11px;background:var(--bg);color:var(--tx);outline:none;width:100%;}
.fi:focus{border-color:var(--gd);background:#FFFEF2;}
textarea.fi{resize:vertical;min-height:72px;}
.nw{position:relative;}
.nw .fi{padding-right:52px;}
.nfmt{position:absolute;right:13px;top:50%;transform:translateY(-50%);font-size:13px;font-weight:900;color:var(--gdk);font-family:'DM Mono',monospace;pointer-events:none;}
.ms{display:flex;flex-direction:column;gap:9px;}
.mr{display:flex;align-items:center;gap:10px;}
.mr input[type=checkbox]{width:18px;height:18px;accent-color:var(--gdk);cursor:pointer;}
.mr label{font-size:13px;font-weight:700;cursor:pointer;}
.mo{display:grid;grid-template-columns:repeat(3,1fr);gap:7px;margin-top:4px;}
.mopt{font-size:11px;font-weight:800;font-family:inherit;padding:7px 4px;border:2px solid var(--bd);border-radius:10px;background:var(--sf2);color:var(--tx2);cursor:pointer;text-align:center;}
.mopt:hover,.mopt.sl{background:var(--gdbg);border-color:var(--gd);color:var(--gdk);}
.fsql-opts{display:grid;grid-template-columns:repeat(3,1fr);gap:8px;}
.fsql-opt{font-size:12px;font-weight:800;font-family:inherit;padding:10px 8px;border:2.5px solid var(--bd);border-radius:11px;background:var(--sf2);color:var(--tx2);cursor:pointer;text-align:center;}
.fsql-opt.sel-fsql{background:var(--gdbg);border-color:var(--gd);color:var(--gdk);}
.fsql-opt.sel-yet{background:var(--orbg);border-color:var(--orb);color:var(--or);}
.fsql-opt.sel-nfsql{background:var(--rdbg);border-color:var(--rdb);color:var(--rd);}
.fp{padding:12px;border-radius:11px;font-size:13px;font-weight:900;text-align:center;border:2.5px solid;margin-top:6px;}
.fp.yes{background:var(--gdbg);color:var(--gdk);border-color:#EED060;}
.fp.no{background:var(--rdbg);color:var(--rd);border-color:var(--rdb);}
.qr{display:flex;gap:10px;flex-wrap:wrap;}
.qc{display:flex;align-items:center;gap:8px;background:var(--sf2);border:2px solid var(--bd);border-radius:100px;padding:8px 14px;cursor:pointer;}
.qc:hover,.qc.on{background:var(--blbg);border-color:var(--blb);}
.qc input{width:15px;height:15px;accent-color:var(--bl);cursor:pointer;}
.qc label{font-size:12px;font-weight:800;cursor:pointer;}
.ma{display:flex;gap:10px;justify-content:flex-end;margin-top:20px;}
.mc{font-family:inherit;font-size:13px;font-weight:700;padding:10px 20px;border:2px solid var(--bd);border-radius:var(--r);background:var(--sf2);color:var(--tx2);cursor:pointer;}
.msv{font-family:inherit;font-size:13px;font-weight:900;padding:10px 26px;border:none;border-radius:var(--r);background:linear-gradient(135deg,var(--gd),var(--gdk));color:#FFF7CC;cursor:pointer;box-shadow:0 5px 14px rgba(180,130,0,.32);display:flex;align-items:center;gap:7px;}
.msv:disabled{opacity:.5;cursor:not-allowed;}
@media(max-width:800px){
  .wrap{flex-direction:column;padding:14px;}
  .sidebar{width:100%;}
  .sc{position:static;}
  .summary{grid-template-columns:repeat(2,1fr);}
  .cda{grid-template-columns:repeat(2,1fr);}
  .fg{grid-template-columns:1fr;}
  .ov{padding:12px;align-items:flex-start;}
  .modal{max-height:none;}
  .mo{grid-template-columns:repeat(2,1fr);}
  .mgr-toast{bottom:16px;right:16px;}
}
</style>
</head>
<body>
<div id="header-root"></div>
<div id="main-root"></div>
<div id="modal-root"></div>
<div id="toast-root"></div>

<script>
const NOTION_DS='1473eb30-4ab0-4f76-a443-d55db642b0a1';
const DL_TH=100000,DAU_TH=10000;
const MMP_LIST=['AppsFlyer','Adjust','Kochava','Branch','Singular','Other'];
const DOWS=['Su','Mo','Tu','We','Th','Fr','Sa'];
const MONTHS=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
const STORAGE_KEY='kgg_v3';
const MGR_MSGS=['잘했어요! 🎉','오늘도 황금알! 🥚','멋져요! 👏','Golden work! ✨','Keep hatching! 🪿','최고야! 🌟'];
const MGR_IMG='data:image/png;base64,';

function fmtNum(n){n=+n;if(!n&&n!==0)return'—';if(n>=1000000)return(n/1000000).toFixed(1).replace(/\.0$/,'')+'M';if(n>=1000)return(n/1000).toFixed(1).replace(/\.0$/,'')+'K';return n.toLocaleString();}
function getWeekOf(ds){const d=ds?new Date(ds+'T00:00:00'):new Date();const m=new Date(d);m.setDate(d.getDate()-((d.getDay()+6)%7));const f=x=>`${x.getFullYear()}-${String(x.getMonth()+1).padStart(2,'0')}-${String(x.getDate()).padStart(2,'0')}`;return f(m);}
function weekLabel(ws){if(!ws)return'';const m=new Date(ws+'T00:00:00');const s=new Date(m);s.setDate(m.getDate()+6);const f=x=>`${x.getMonth()+1}/${x.getDate()}`;return`${f(m)}–${f(s)}`;}
function calcAuto(dl,dau,mmp){return(+dl>=DL_TH&&+dau>=DAU_TH&&mmp)?'fsql':'nfsql';}
function emptyForm(){return{company:'',app:'',date:new Date().toISOString().split('T')[0],bdr:'',seller:'',dl:'',dau:'',mmp:false,mmpTool:'',mmpOther:'',fsqlStatus:'yet',paCheck:false,note:'',leaderComment:'',androidUrl:'',iosUrl:'',sfLink:''};}
function loadCards(){try{return JSON.parse(localStorage.getItem(STORAGE_KEY))||[];}catch(e){return[];}}
function saveLocal(c){try{localStorage.setItem(STORAGE_KEY,JSON.stringify(c));}catch(e){}}

let S={
  bdrName:localStorage.getItem('kgg_bdr')||'',
  cards:loadCards(),
  modal:false,editId:null,ldrId:null,
  form:emptyForm(),
  calY:new Date().getFullYear(),calM:new Date().getMonth(),
  fw:getWeekOf(),
  notionStatus:'idle',
  mgrTimer:null,showMgr:false,mgrMsg:'',
};

// ── Notion sync ──────────────────────────────────────────────────────────
async function syncToNotion(card){
  try{
    const fsqlVal = card.fsqlStatus==='fsql'?'FSQL':card.fsqlStatus==='nfsql'?'Non-FSQL':'TBD';
    const mmpTool = card.mmpTool==='Other'?card.mmpOther||'Other':card.mmpTool||'';
    const body={
      parent:{data_source_id:NOTION_DS},
      pages:[{properties:{
        'Company Name': card.company,
        'App Name': card.app,
        'BDR': card.bdr,
        'Seller': card.seller||'',
        'date:Meeting Date:start': card.date,
        'date:Meeting Date:is_datetime': 0,
        'Downloads (DL)': +card.dl||null,
        'DAU': +card.dau||null,
        'MMP': card.mmp?'__YES__':'__NO__',
        'MMP Tool': mmpTool,
        'FSQL': fsqlVal,
        'FSQL Check': card.fsqlStatus==='fsql'?'__YES__':'__NO__',
        'PA Check': card.paCheck?'__YES__':'__NO__',
        'Meeting Notes': card.note||'',
        'Sales Leader Comment': card.leaderComment||'',
        'Android URL': card.androidUrl||null,
        'iOS URL': card.iosUrl||null,
        'SF Link': card.sfLink||null,
        'Week': weekLabel(getWeekOf(card.date)),
      }}]
    };
    // Call Claude MCP via postMessage to parent frame
    // Since we can't call Notion API directly from Vercel, we'll use a workaround:
    // Store pending syncs and show status to user
    const pending = JSON.parse(localStorage.getItem('kgg_pending')||'[]');
    pending.push({card, timestamp: Date.now()});
    localStorage.setItem('kgg_pending', JSON.stringify(pending));
    return true;
  }catch(e){return false;}
}

// ── Render helpers (no scroll jump) ──────────────────────────────────────
function getWeeks(){const w={};S.cards.forEach(c=>{const k=getWeekOf(c.date);w[k]=(w[k]||0)+1;});return Object.keys(w).sort().reverse();}
function filtered(){if(!S.fw)return S.cards;return S.cards.filter(c=>getWeekOf(c.date)===S.fw);}

function renderHeader(){
  const h=`<header>
  <div class="logo"><span class="logo-goose">🪿</span><div class="logo-txt"><div class="t">K-Golden Goose</div><div class="s">Appier BDR · Weekly Review</div></div></div>
  <div class="hdr-r">
    <span class="wchip">📅 ${S.fw?weekLabel(S.fw):'All Time'}</span>
    ${S.bdrName?`<span class="bpill" onclick="resetBDR()">🥚 ${S.bdrName}</span>`:''}
  </div>
</header>`;
  document.getElementById('header-root').innerHTML=h;
}

function renderMain(){
  const fc=filtered();
  const tot=fc.length,fy=fc.filter(c=>c.fsqlStatus==='fsql').length,yet=fc.filter(c=>c.fsqlStatus==='yet').length,pa=fc.filter(c=>c.paCheck).length;
  const rt=tot?Math.round(fy/tot*100):0;
